# Lab API Server — Environment Variables
# Copy this to .env if you need to override defaults
# Or just run the server — it works out of the box!

# (Optional) Port the API server listens on (Default: 4000)
# PORT=4000

# (Optional) Absolute path to the directory containing docker-compose.yml
# Defaults to the parent directory of this API server.
# LAB_DIR=/path/to/your/labs
