# Lab API Server — Environment Variables
# Copy this to .env and fill in your values

# Secret token used by the dashboard to authenticate requests
API_SECRET=changeme_use_a_strong_random_string

# Absolute path to the directory containing docker-compose.yml
# Defaults to ~/pentest-lab (same as the shell script)
LAB_DIR="C:\Users\atish\Downloads\AITesterBlueprint\Security\P2_Sec_Application"

# Port the API server listens on
PORT=4100

# (Optional) Your ngrok authtoken – used by start-with-ngrok.sh
NGROK_AUTHTOKEN=
